# Possibilista local container environment
#
# Copy to .env if you need to override defaults:
#   cp .env.example .env

# PostgreSQL container credentials. Defaults match backend/config.py.
POSTGRES_USER=possibilista
POSTGRES_PASSWORD=possibilista
POSTGRES_DB=possibilista

# Host ports exposed by Docker Compose.
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000

# Backend runtime configuration.
# Inside Docker Compose, the backend must use the postgres service hostname.
DATABASE_URL=postgresql+psycopg://possibilista:possibilista@postgres:5432/possibilista

# Frontend runtime configuration reserved for API-client code that needs an absolute URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
